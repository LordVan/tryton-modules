      <field name="extra_contacts" />
    </page>
  </xpath>
  <xpath expr="/form/label[@name='invoice_party']"
	 position="before">
    <label name="payment_term" />
    <field name="payment_term" />
  </xpath>
  <xpath expr="/form/notebook/page/field[@name='sale_date']"
	 position="after">
