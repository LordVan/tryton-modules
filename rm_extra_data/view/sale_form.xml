      <label name="offer_inquirydate" />
      <field name="offer_inquirydate" />
      <label name="offer_number"/>
      <field name="offer_number" />
      <newline />
      <label name="offer_date" />
      <field name="offer_date" />
      <label name="offer_validuntil" />
      <field name="offer_validuntil" />
      <newline />
      <label name="offer_delivery" />
      <field name="offer_delivery" colspan="3" />
      <newline />
      <label name="quoted_by" />
      <field name="quoted_by" />
      <newline />
      <label name="offer_hidetotal" />
      <field name="offer_hidetotal" />
      <newline />
